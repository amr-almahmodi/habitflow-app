<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitFlow.HistoryPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 🔹 Top Bar -->
        <Grid Grid.Row="0"
              BackgroundColor="#2E7D32"
              Padding="10,25,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Back icon image -->
            <Image Grid.Column="0"
       Source="back.png"
       WidthRequest="25"
       HeightRequest="25"
       VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Image.GestureRecognizers>
            </Image>


            <!-- Title -->
            <Label Grid.Column="1"
                   Text="Habit History"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"
                   VerticalOptions="Center" />

            <!-- About icon image -->
            <Image Grid.Column="2"
       Source="about.png"
       WidthRequest="25"
       HeightRequest="25"
       VerticalOptions="Center"
       HorizontalOptions="End">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAboutTapped" />
                </Image.GestureRecognizers>
            </Image>

        </Grid>

        <!-- 🔹 Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="12">

                <Frame CornerRadius="10"
                       Padding="0"
                       HasShadow="True"
                       BackgroundColor="White">

                    <VerticalStackLayout Spacing="0">

                        <!-- Section title bar -->
                        <Grid BackgroundColor="#7BA96B"
                              Padding="12,8">
                            <Label Text="History"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White" />
                        </Grid>

                        <!-- Column headers -->
                        <Grid Padding="12,8"
                              BackgroundColor="#F3F3F3"
                              ColumnDefinitions="0.25*,0.45*,0.30*">

                            <Label Grid.Column="0"
                                   Text="Date"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#555555"
                                   HorizontalTextAlignment="Start" />

                            <Label Grid.Column="1"
                                   Text="Habit"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#555555"
                                   HorizontalTextAlignment="Start" />

                            <Label Grid.Column="2"
                                   Text="Status"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#555555"
                                   HorizontalTextAlignment="End" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="#DDDDDD" />

                        <!-- Rows -->
                        <CollectionView x:Name="HistoryCollectionView"
                                        Margin="0"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,6"
                                          ColumnDefinitions="0.25*,0.45*,0.30*"
                                          ColumnSpacing="8">

                                        <!-- Date -->
                                        <Label Grid.Column="0"
                                               Text="{Binding Date, StringFormat='{}{0:dd MMM}'}"
                                               FontSize="14"
                                               TextColor="#333333"
                                               HorizontalTextAlignment="Start" />

                                        <!-- Habit name -->
                                        <Label Grid.Column="1"
                                               Text="{Binding HabitName}"
                                               FontSize="14"
                                               TextColor="#333333"
                                               HorizontalTextAlignment="Start" />

                                        <!-- Status chip -->
                                        <Frame Grid.Column="2"
                                               Padding="10,4"
                                               CornerRadius="12"
                                               HasShadow="False"
                                               BackgroundColor="#E53935"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center">

                                            <Frame.Triggers>
                                                <!-- Green if Done -->
                                                <DataTrigger TargetType="Frame"
                                                             Binding="{Binding Status}"
                                                             Value="Done">
                                                    <Setter Property="BackgroundColor"
                                                            Value="#4CAF50" />
                                                </DataTrigger>
                                                <!-- Red if Missed -->
                                                <DataTrigger TargetType="Frame"
                                                             Binding="{Binding Status}"
                                                             Value="Missed">
                                                    <Setter Property="BackgroundColor"
                                                            Value="#E53935" />
                                                </DataTrigger>
                                            </Frame.Triggers>

                                            <Label Text="{Binding Status}"
                                                   FontSize="13"
                                                   TextColor="White"
                                                   HorizontalTextAlignment="Center" />
                                        </Frame>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- 🔹 Bottom Navigation -->
        <Grid Grid.Row="2"
              BackgroundColor="White"
              Padding="0,10"
              ColumnDefinitions="*,*">

            <!-- Home icon -->
            <Label Grid.Column="0"
                   Text="&#x2302;"
                   FontSize="34"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="#000000">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </Label.GestureRecognizers>
            </Label>

            <!-- Menu icon -->
            <Label Grid.Column="1"
                   Text="&#x2630;"
                   FontSize="34"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="#000000">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMenuTapped" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>

    </Grid>
</ContentPage>
