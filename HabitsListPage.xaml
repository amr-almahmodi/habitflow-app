<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitFlow.HabitsListPage"
             BackgroundColor="#F5F5F5"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 🔹 Top Bar -->
        <Grid Grid.Row="0"
              BackgroundColor="#2E7D32"
              Padding="10,25,10,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Back icon image -->
            <Image Grid.Column="0"
       Source="back.png"
       WidthRequest="25"
       HeightRequest="25"
       VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Image.GestureRecognizers>
            </Image>


            <!-- Title -->
            <Label Grid.Column="1"
                   Text="Habits List"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"
                   VerticalOptions="Center" />

            <!-- About icon image -->
            <Image Grid.Column="2"
       Source="about.png"
       WidthRequest="25"
       HeightRequest="25"
       VerticalOptions="Center"
       HorizontalOptions="End">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAboutTapped" />
                </Image.GestureRecognizers>
            </Image>

        </Grid>

        <!-- 🔹 Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="10">

                <!-- Header card -->
                <Frame CornerRadius="10"
                       BackgroundColor="#7BA96B"
                       Padding="12">
                    <Label Text="Habits List"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="White" />
                </Frame>

                <!-- Each habit item is a Frame with TapGesture -->
                <Frame CornerRadius="10" BackgroundColor="White" Padding="12">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHabitTapped"
                                              CommandParameter="FootBall" />
                    </Frame.GestureRecognizers>
                    <Label Text="FootBall" FontSize="16" />
                </Frame>

                <Frame CornerRadius="10" BackgroundColor="White" Padding="12">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHabitTapped"
                                              CommandParameter="Swimming" />
                    </Frame.GestureRecognizers>
                    <Label Text="Swimming" FontSize="16" />
                </Frame>

                <Frame CornerRadius="10" BackgroundColor="White" Padding="12">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHabitTapped"
                                              CommandParameter="Read" />
                    </Frame.GestureRecognizers>
                    <Label Text="Read" FontSize="16" />
                </Frame>

                <Frame CornerRadius="10" BackgroundColor="White" Padding="12">

                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHabitTapped"
                                              CommandParameter="Gym" />
                    </Frame.GestureRecognizers>
                    <Label Text="Gym" FontSize="16" />
                </Frame>

                <Frame CornerRadius="10" BackgroundColor="White" Padding="12">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHabitTapped"
                                              CommandParameter="Walking" />
                    </Frame.GestureRecognizers>
                    <Label Text="Walking" FontSize="16" />
                </Frame>

                <Frame CornerRadius="10" BackgroundColor="White" Padding="12">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHabitTapped"
                                              CommandParameter="Nap" />
                    </Frame.GestureRecognizers>
                    <Label Text="Nap" FontSize="16" />
                </Frame>

                <Frame CornerRadius="10" BackgroundColor="White" Padding="12">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHabitTapped"
                                              CommandParameter="Cook" />
                    </Frame.GestureRecognizers>
                    <Label Text="Cook" FontSize="16" />
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- 🔹 Bottom Navigation -->
        <Grid Grid.Row="2"
              BackgroundColor="White"
              Padding="0,10"
              ColumnDefinitions="*,*">

            <!-- Home icon -->
            <Label Grid.Column="0"
                   Text="&#x2302;"
                   FontSize="34"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="#000000">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </Label.GestureRecognizers>
            </Label>

            <!-- Menu icon -->
            <Label Grid.Column="1"
                   Text="&#x2630;"
                   FontSize="34"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="#000000">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMenuTapped" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>

    </Grid>
</ContentPage>
