<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitFlow.MenuListPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 🔹 Top Green Bar -->
        <Grid Grid.Row="0"
              BackgroundColor="#2E7D32"
              Padding="10,25,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Back icon image -->
            <Image Grid.Column="0"
Source="back.png"
WidthRequest="25"
HeightRequest="25"
VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Image.GestureRecognizers>
            </Image>

            <!-- Title -->
            <Label Grid.Column="1"
                   Text="Menu List"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"
                   VerticalOptions="Center" />

            <!-- About icon image -->
            <Image Grid.Column="2"
Source="about.png"
WidthRequest="25"
HeightRequest="25"
VerticalOptions="Center"
HorizontalOptions="End">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAboutTapped" />
                </Image.GestureRecognizers>
            </Image>
        </Grid>

        <!-- 🔹 Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24" Spacing="20">

                <!-- Habits List -->
                <Button Text="Habits List"
                        FontSize="18"
                        TextColor="White"
                        BackgroundColor="#7BA96B"
                        CornerRadius="24"
                        HeightRequest="60"
                        Clicked="OnHabitsListClicked" />

                <!-- Progress -->
                <Button Text="Progress"
                        FontSize="18"
                        TextColor="White"
                        BackgroundColor="#7BA96B"
                        CornerRadius="24"
                        HeightRequest="60"
                        Clicked="OnProgressClicked" />

                <!-- Habit History -->
                <Button Text="Habit History"
                        FontSize="18"
                        TextColor="White"
                        BackgroundColor="#7BA96B"
                        CornerRadius="24"
                        HeightRequest="60"
                        Clicked="OnHistoryClicked" />

                <!-- (Reminders button removed) -->

            </VerticalStackLayout>
        </ScrollView>

        <!-- 🔹 Bottom Navigation Bar -->
        <Grid Grid.Row="2"
              BackgroundColor="White"
              Padding="0,10"
              ColumnDefinitions="*,*">

            <!-- Home -->
            <Label Grid.Column="0"
                   Text="&#x2302;"
                   FontSize="34"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="#000000">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </Label.GestureRecognizers>
            </Label>

            <!-- Menu icon (highlighted) -->
            <Label Grid.Column="1"
                   Text="&#x2630;"
                   FontSize="34"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="#2E7D32">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMenuTapped" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>

    </Grid>
</ContentPage>
