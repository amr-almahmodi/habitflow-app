<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitFlow.AboutPage"
             BackgroundColor="#F5F5F5"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 🔹 Top Bar -->
        <Grid Grid.Row="0"
              BackgroundColor="#2E7D32"
              Padding="10,25,10,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Back icon image -->
            <Image Grid.Column="0"
       Source="back.png"
       WidthRequest="25"
       HeightRequest="25"
       VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="BackTapped" />
                </Image.GestureRecognizers>
            </Image>


            <!-- Title -->
            <Label Grid.Column="1"
                   Text="About"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"
                   VerticalOptions="Center" />
        </Grid>

        <!-- 🔹 Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- App Logo -->
                <Image Source="habitflow_logo.png"
                       WidthRequest="120"
                       HeightRequest="120"
                       HorizontalOptions="Center"/>

                <!-- App Name & Version -->
                <Label Text="HabitFlow"
                       FontSize="24"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#000"/>

                <Label Text="Version 1.0"
                       FontSize="14"
                       HorizontalOptions="Center"
                       TextColor="#666"/>

                <!-- Description -->
                <Frame CornerRadius="10"
                       BackgroundColor="White"
                       Padding="15">
                    <Label Text="About App: HabitFlow is a simple and smart habit-tracking app designed to help users build better routines and stay consistent.
The app provides clean visuals, automatic scheduling, and helpful progress tracking so users can focus on improving their daily habits with ease."
                           FontSize="14"
                           TextColor="#444"/>
                </Frame>

                <!-- Contact section -->
                <VerticalStackLayout Spacing="6">
                    

                    <Label FontSize="14"
               TextColor="Black"
               Text="Developed by: Amr Almahmodi" />

                    <Label FontSize="14"
               TextColor="Black"
               Text="Email: amrmahmodi02@gmail.com" />

                    <Label FontSize="14"
               TextColor="Black"
               Text="Phone: ‪+60 1169430090 ‬" />
                </VerticalStackLayout>
            </VerticalStackLayout>

        </ScrollView>

        <!-- 🔹 Bottom Navigation Bar -->
        <Grid Grid.Row="2"
      BackgroundColor="White"
      Padding="0,10"
      ColumnDefinitions="*,*">
            <!-- Home -->
            <Label Grid.Column="0"
           Text="&#x2302;"
           FontSize="34"
           HorizontalTextAlignment="Center"
           VerticalTextAlignment="Center"
           HorizontalOptions="Center"
           VerticalOptions="Center"
           TextColor="#000000">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="GoHome" />
                </Label.GestureRecognizers>
            </Label>
            <!-- Menu -->
            <Label Grid.Column="1"
           Text="&#x2630;"
           FontSize="34"
           HorizontalTextAlignment="Center"
           VerticalTextAlignment="Center"
           HorizontalOptions="Center"
           VerticalOptions="Center"
           TextColor="#000000">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMenuTapped" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>

    </Grid>
</ContentPage>
